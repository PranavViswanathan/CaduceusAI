# PostgreSQL
POSTGRES_USER=medical_user
POSTGRES_PASSWORD=medical_pass
POSTGRES_DB=medical_ai
DATABASE_URL=postgresql://medical_user:medical_pass@postgres:5432/medical_ai

# Redis
REDIS_URL=redis://redis:6379

# Ollama
OLLAMA_URL=http://ollama:11434

# JWT (generate a strong random secret for production)
JWT_SECRET=super-secret-jwt-key-change-in-production-min-32-chars

# Fernet encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# Internal service-to-service API key
INTERNAL_API_KEY=internal-service-api-key-change-in-production

# LoRA retraining (retrain-worker service)
FINE_TUNED_MODEL_NAME=medical-risk-ft
MIN_RETRAIN_BATCH=5
RETRAIN_POLL_INTERVAL_SECONDS=300

# Next.js public env vars (used at build time — must match exposed ports)
NEXT_PUBLIC_PATIENT_API_URL=http://localhost:8001
NEXT_PUBLIC_DOCTOR_API_URL=http://localhost:8002
NEXT_PUBLIC_POSTCARE_API_URL=http://localhost:8003
