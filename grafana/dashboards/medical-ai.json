{
  "id": null,
  "uid": "medical-ai-platform",
  "title": "Medical AI Platform",
  "tags": ["medical-ai", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "query": "patient_api,doctor_api,postcare_api",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(medical_ai_traces_spanmetrics_calls_total{service_name=~\"$service\", span_name=~\"(GET|POST|PUT|DELETE|PATCH) /.*\"}[5m])) by (service_name)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "title": "HTTP P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(medical_ai_traces_spanmetrics_duration_milliseconds_bucket{service_name=~\"$service\", span_name=~\"(GET|POST|PUT|DELETE|PATCH) /.*\"}[5m])) by (le, service_name))",
          "legendFormat": "p95 {{service_name}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(medical_ai_traces_spanmetrics_duration_milliseconds_bucket{service_name=~\"$service\", span_name=~\"(GET|POST|PUT|DELETE|PATCH) /.*\"}[5m])) by (le, service_name))",
          "legendFormat": "p50 {{service_name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 3,
      "title": "Ollama Inference Duration P95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(medical_ai_ollama_request_duration_seconds_bucket[5m])) by (le, ollama_operation, service_name)) * 1000",
          "legendFormat": "p95 {{service_name}}/{{ollama_operation}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(medical_ai_ollama_request_duration_seconds_bucket[5m])) by (le, ollama_operation, service_name)) * 1000",
          "legendFormat": "p50 {{service_name}}/{{ollama_operation}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 4,
      "title": "Ollama Fallback Rate (rule-based)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(medical_ai_ollama_fallback_total[5m])",
          "legendFormat": "{{service_name}} / {{ollama_operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "DB Query Rate (ops/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(medical_ai_traces_spanmetrics_calls_total{span_name=~\"SELECT|INSERT|UPDATE|DELETE\", service_name=~\"$service\"}[5m])) by (span_name, service_name)",
          "legendFormat": "{{service_name}} {{span_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 6,
      "title": "DB Query P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(medical_ai_traces_spanmetrics_duration_milliseconds_bucket{span_name=~\"SELECT|INSERT|UPDATE|DELETE\", service_name=~\"$service\"}[5m])) by (le, service_name))",
          "legendFormat": "p95 {{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 7,
      "title": "Redis Operations Rate (ops/s)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(medical_ai_traces_spanmetrics_calls_total{span_name=~\"GET|SET|SETEX|DEL|LPUSH|PING\", service_name=~\"$service\"}[5m])) by (span_name)",
          "legendFormat": "{{span_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 8,
      "title": "Agent Node Duration P95 (ms)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(medical_ai_agent_node_duration_seconds_bucket[5m])) by (le, agent_node)) * 1000",
          "legendFormat": "{{agent_node}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      }
    },
    {
      "id": 9,
      "title": "Agent Node Call Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(medical_ai_traces_spanmetrics_calls_total{span_name=~\"agent\\..*\"}[5m])) by (span_name)",
          "legendFormat": "{{span_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      }
    }
  ]
}
